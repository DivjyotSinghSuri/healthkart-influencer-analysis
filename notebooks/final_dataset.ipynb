   "source": [
    "CREATE OR REPLACE VIEW final_dataset AS\n",
    "SELECT \n",
    "  f.*,\n",
    "  i.category,\n",
    "  i.platform,\n",
    "  i.follower_count\n",
    "FROM healthkart_db.fact_campaign f\n",
    "JOIN healthkart_db.influencers i\n",
    "ON f.influencer_id = i.id;"
   ]
